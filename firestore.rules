rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return signedIn() && request.auth.token.email == 'hzdjdndb@gmail.com';
    }

    function isOwner(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function validDiscountPercent(percent) {
      return percent in [0, 5, 10, 15, 20, 50];
    }

    function validPaymentMethod(method) {
      return method in ['thaqr', 'truemoney', 'crypto'];
    }

    function orderCreateFieldsAreValid() {
      return request.resource.data.keys().hasOnly([
          'userId',
          'email',
          'items',
          'paymentMethod',
          'totalUsd',
          'totalDisplay',
          'discountApplied',
          'status',
          'slipUrl',
          'createdAt'
        ])
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.email == request.auth.token.email
        && request.resource.data.items is list
        && request.resource.data.items.size() > 0
        && request.resource.data.items.size() <= 50
        && validPaymentMethod(request.resource.data.paymentMethod)
        && request.resource.data.totalUsd is number
        && request.resource.data.totalUsd > 0
        && request.resource.data.totalUsd < 10000
        && request.resource.data.totalDisplay is string
        && validDiscountPercent(request.resource.data.discountApplied)
        && request.resource.data.status == 'pending'
        && request.resource.data.slipUrl is string
        && request.resource.data.createdAt == request.time;
    }

    function userProfileCreateFieldsAreValid(userId) {
      return isOwner(userId)
        && request.resource.data.keys().hasOnly(['email', 'balance', 'createdAt'])
        && request.resource.data.email == request.auth.token.email
        && request.resource.data.balance is number
        && request.resource.data.createdAt == request.time;
    }

    // Client-only spin/discount logic cannot be made perfectly fraud-proof in rules.
    // This keeps profile fields constrained until the spin flow moves server-side.
    function userProfileUpdateFieldsAreValid() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(['activeDiscount', 'spinsAvailable'])
        && request.resource.data.email == resource.data.email
        && request.resource.data.balance == resource.data.balance
        && request.resource.data.createdAt == resource.data.createdAt
        && (!('spinsAvailable' in request.resource.data)
          || (request.resource.data.spinsAvailable is number
            && request.resource.data.spinsAvailable >= 0
            && request.resource.data.spinsAvailable <= 100))
        && (!('activeDiscount' in request.resource.data)
          || request.resource.data.activeDiscount == null
          || (request.resource.data.activeDiscount.percent in [5, 10, 15, 20, 50]
            && request.resource.data.activeDiscount.expiresAt is timestamp));
    }

    match /items/{itemId} {
      allow read: if signedIn();
      allow create, update, delete: if isAdmin();
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if userProfileCreateFieldsAreValid(userId);
      allow update: if isOwner(userId) && userProfileUpdateFieldsAreValid();
      allow delete: if false;
    }

    match /orders/{orderId} {
      allow create: if signedIn() && orderCreateFieldsAreValid();
      allow read: if isAdmin() || (signedIn() && resource.data.userId == request.auth.uid);
      allow update: if isAdmin()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status'])
        && request.resource.data.status in ['pending', 'delivered'];
      allow delete: if false;
    }
  }
}

